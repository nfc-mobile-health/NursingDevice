<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Form Container -->
        <LinearLayout
            android:id="@+id/formContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Medical Information Form"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:gravity="center"
                android:padding="16dp" />

            <!-- Start Voice Input Button -->
            <Button
                android:id="@+id/startVoiceBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Start Voice Input"
                android:textColor="#ffffff"
                android:background="#4CAF50"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Nurse ID Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#222222"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nurse Information"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_marginBottom="8dp" />

                <!-- Nurse ID with Voice Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/nurseIdInput"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:hint="Nurse ID *"
                        android:textColorHint="#888888"
                        android:textColor="#ffffff"
                        android:inputType="textCapCharacters"
                        android:background="#333333"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp" />

                    <ImageButton
                        android:id="@+id/voiceNurseIdBtn"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:background="#444444"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        android:contentDescription="Voice input for Nurse ID" />

                </LinearLayout>

            </LinearLayout>

            <!-- Patient Information Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#222222"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Patient Details"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_marginBottom="8dp" />

                <!-- Name with Voice Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/nameInput"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:hint="Patient Name *"
                        android:textColorHint="#888888"
                        android:textColor="#ffffff"
                        android:inputType="textPersonName"
                        android:background="#333333"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp" />

                    <ImageButton
                        android:id="@+id/voiceNameBtn"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:background="#444444"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        android:contentDescription="Voice input for Patient Name" />

                </LinearLayout>

                <!-- Blood Group Spinner -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Blood Group"
                    android:textSize="12sp"
                    android:textColor="#cccccc"
                    android:layout_marginTop="8dp" />

                <Spinner
                    android:id="@+id/bloodGroupSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="#333333"
                    android:layout_marginBottom="8dp" />

                <!-- Gender Spinner -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gender"
                    android:textSize="12sp"
                    android:textColor="#cccccc"
                    android:layout_marginTop="8dp" />

                <Spinner
                    android:id="@+id/genderSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="#333333"
                    android:layout_marginBottom="8dp" />

                <!-- Date of Birth (Manual Only - No Voice) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date of Birth (DD/MM/YYYY) - Tap to select"
                    android:textSize="12sp"
                    android:textColor="#cccccc"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/dobInput"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textColorHint="#888888"
                    android:textColor="#ffffff"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:background="#333333"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp" />

            </LinearLayout>

            <!-- Vital Signs Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#222222"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vital Signs"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_marginBottom="8dp" />

                <!-- Blood Pressure with Voice Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/bpInput"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:hint="Blood Pressure (e.g., 120/80)"
                        android:textColorHint="#888888"
                        android:textColor="#ffffff"
                        android:inputType="text"
                        android:background="#333333"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp" />

                    <ImageButton
                        android:id="@+id/voiceBpBtn"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:background="#444444"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        android:contentDescription="Voice input for Blood Pressure" />

                </LinearLayout>

                <!-- Heart Rate with Voice Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/heartRateInput"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:hint="Heart Rate (bpm)"
                        android:textColorHint="#888888"
                        android:textColor="#ffffff"
                        android:inputType="number"
                        android:background="#333333"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp" />

                    <ImageButton
                        android:id="@+id/voiceHeartRateBtn"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:background="#444444"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        android:contentDescription="Voice input for Heart Rate" />

                </LinearLayout>

                <!-- Respiratory Rate with Voice Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/respiratoryRateInput"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:hint="Respiratory Rate (breaths/min)"
                        android:textColorHint="#888888"
                        android:textColor="#ffffff"
                        android:inputType="number"
                        android:background="#333333"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp" />

                    <ImageButton
                        android:id="@+id/voiceRespRateBtn"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:background="#444444"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        android:contentDescription="Voice input for Respiratory Rate" />

                </LinearLayout>

                <!-- Body Temperature with Voice Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/temperatureInput"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:hint="Body Temperature (°F)"
                        android:textColorHint="#888888"
                        android:textColor="#ffffff"
                        android:inputType="numberDecimal"
                        android:background="#333333"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp" />

                    <ImageButton
                        android:id="@+id/voiceTempBtn"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:background="#444444"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        android:contentDescription="Voice input for Temperature" />

                </LinearLayout>

            </LinearLayout>

            <!-- Generate Button -->
            <Button
                android:id="@+id/generateButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Generate Medical Report"
                android:textColor="#000000"
                android:background="#ffffff"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Preview Container -->
        <LinearLayout
            android:id="@+id/previewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="File Preview"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:gravity="center"
                android:padding="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#222222"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/fileNameText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="File name: medical_data.txt"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_marginBottom="12dp" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="300dp">

                    <TextView
                        android:id="@+id/fileContentText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:background="#0a0a0a"
                        android:padding="12dp"
                        android:textColor="#ffffff" />

                </ScrollView>

            </LinearLayout>

            <Button
                android:id="@+id/editButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Edit Form"
                android:textColor="#000000"
                android:background="#888888"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/sendNfcButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Send via NFC"
                android:textColor="#000000"
                android:background="#ffffff"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>